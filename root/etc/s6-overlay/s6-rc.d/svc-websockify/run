#!/usr/bin/with-contenv bash

echo "[svc-websockify] Waiting for VNC backend on 127.0.0.1:5901..."
for i in $(seq 1 30); do
  if timeout 1 bash -c "echo > /dev/tcp/127.0.0.1/5901" 2>/dev/null; then
    echo "[svc-websockify] Backend ready after ${i}s"
    break
  fi
  sleep 1
done

echo "[svc-websockify] Starting websockify proxy on 6902 -> localhost:5901"
exec s6-setuidgid abc \
  websockify --verbose 6902 127.0.0.1:5901
